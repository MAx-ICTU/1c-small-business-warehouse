#Если Сервер Тогда

Функция ПолучитьДефицитыОстатков(ТаблицаТоваров, Склад, Момент) Экспорт

	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("Номенклатура");
	Результат.Колонки.Добавить("КоличествоТребуется", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 3)));
	Результат.Колонки.Добавить("КоличествоОстаток", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 3)));
	
	Если НЕ ЗначениеЗаполнено(Склад) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	СУММА(Товары.Количество) КАК КоличествоТребуется
	|ПОМЕСТИТЬ ВТТоварыДокумента
	|ИЗ
	|	&ТаблицаТоваров КАК Товары
	|ГДЕ
	|	Товары.Количество > 0
	|СГРУППИРОВАТЬ ПО
	|	Товары.Номенклатура
	|;
	|
	|ВЫБРАТЬ
	|	ВТТоварыДокумента.Номенклатура КАК Номенклатура,
	|	ВТТоварыДокумента.КоличествоТребуется КАК КоличествоТребуется,
	|	ЕСТЬNULL(Остатки.КоличествоОстаток, 0) КАК КоличествоОстаток
	|ИЗ
	|	ВТТоварыДокумента КАК ВТТоварыДокумента
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТоваров.Остатки(&Момент,
	|			Склад = &Склад
	|				И Номенклатура В (ВЫБРАТЬ Номенклатура ИЗ ВТТоварыДокумента)) КАК Остатки
	|		ПО ВТТоварыДокумента.Номенклатура = Остатки.Номенклатура
	|ГДЕ
	|	ВТТоварыДокумента.КоличествоТребуется > ЕСТЬNULL(Остатки.КоличествоОстаток, 0)";
	
	Запрос.УстановитьПараметр("ТаблицаТоваров", ТаблицаТоваров);
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("Момент", ?(ЗначениеЗаполнено(Момент), Момент, ТекущаяДата()));
	
	Возврат Запрос.Выполнить().Выгрузить();

КонецФункции

Функция ЕстьДефицитОстатков(ТаблицаТоваров, Склад, Момент, ЗаголовокСообщения = "", ВыводитьСообщения = Истина) Экспорт

	Дефициты = ПолучитьДефицитыОстатков(ТаблицаТоваров, Склад, Момент);
	
	Если Дефициты.Количество() = 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ВыводитьСообщения Тогда
		Если НЕ ПустаяСтрока(ЗаголовокСообщения) Тогда
			Сообщить(ЗаголовокСообщения, СтатусСообщения.Важное);
		КонецЕсли;
		
		Для каждого СтрокаДефицита Из Дефициты Цикл
			ОбщегоНазначения.СообщитьОДефиците(
				СтрокаДефицита.Номенклатура,
				СтрокаДефицита.КоличествоТребуется,
				СтрокаДефицита.КоличествоОстаток);
		КонецЦикла;
	КонецЕсли;
	
	Возврат Истина;

КонецФункции

Функция ЕстьДефицитДляРезерва(ТаблицаТоваров, Склад, Момент, ЗаказИсключение = Неопределено, ВыводитьСообщения = Истина) Экспорт

	Если НЕ ЗначениеЗаполнено(Склад) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	СУММА(Товары.КоличествоРезерв) КАК КоличествоРезерв
	|ПОМЕСТИТЬ ВТРезервДокумента
	|ИЗ
	|	&ТаблицаТоваров КАК Товары
	|ГДЕ
	|	Товары.КоличествоРезерв > 0
	|СГРУППИРОВАТЬ ПО
	|	Товары.Номенклатура
	|;
	|
	|ВЫБРАТЬ
	|	ВТРезервДокумента.Номенклатура КАК Номенклатура,
	|	ВТРезервДокумента.КоличествоРезерв КАК КоличествоРезерв,
	|	ЕСТЬNULL(Остатки.КоличествоОстаток, 0) КАК КоличествоОстаток,
	|	ЕСТЬNULL(Резервы.КоличествоОстаток, 0) КАК КоличествоУжеВРезерве
	|ИЗ
	|	ВТРезервДокумента КАК ВТРезервДокумента
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТоваров.Остатки(&Момент,
	|			Склад = &Склад
	|				И Номенклатура В (ВЫБРАТЬ Номенклатура ИЗ ВТРезервДокумента)) КАК Остатки
	|		ПО ВТРезервДокумента.Номенклатура = Остатки.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТоваров.Остатки(&Момент,
	|			Склад = &Склад
	|				И Номенклатура В (ВЫБРАТЬ Номенклатура ИЗ ВТРезервДокумента)
	|				И ЗаказКлиента <> &ЗаказИсключение) КАК Резервы
	|		ПО ВТРезервДокумента.Номенклатура = Резервы.Номенклатура
	|ГДЕ
	|	ВТРезервДокумента.КоличествоРезерв > (ЕСТЬNULL(Остатки.КоличествоОстаток, 0) - ЕСТЬNULL(Резервы.КоличествоОстаток, 0))";
	
	Запрос.УстановитьПараметр("ТаблицаТоваров", ТаблицаТоваров);
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("Момент", ?(ЗначениеЗаполнено(Момент), Момент, ТекущаяДата()));
	Запрос.УстановитьПараметр("ЗаказИсключение", ?(ЗначениеЗаполнено(ЗаказИсключение), ЗаказИсключение, Документы.ЗаказКлиента.ПустаяСсылка()));
	
	Дефициты = Запрос.Выполнить().Выгрузить();
	
	Если Дефициты.Количество() = 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ВыводитьСообщения Тогда
		Сообщить("Невозможно провести заказ: недостаточно доступного количества для резерва.", СтатусСообщения.Важное);
		
		Для каждого СтрокаДефицита Из Дефициты Цикл
			Доступно = СтрокаДефицита.КоличествоОстаток - СтрокаДефицита.КоличествоУжеВРезерве;
			Сообщить(
				СтрШаблон("Номенклатура '%1': к резерву %2, доступно %3.",
					СтрокаДефицита.Номенклатура,
					Формат(СтрокаДефицита.КоличествоРезерв, "ЧГ=15.3"),
					Формат(Доступно, "ЧГ=15.3")),
				СтатусСообщения.Важное);
		КонецЦикла;
	КонецЕсли;
	
	Возврат Истина;

КонецФункции

Функция ПолучитьОстаткиРезерваПоЗаказу(ТаблицаТоваров, Склад, Момент, ЗаказКлиента) Экспорт

	Результат = Новый Соответствие;
	
	Если НЕ ЗначениеЗаполнено(ЗаказКлиента) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РАЗЛИЧНЫЕ
	|	Товары.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ВТНоменклатураДокумента
	|ИЗ
	|	&ТаблицаТоваров КАК Товары
	|;
	|
	|ВЫБРАТЬ
	|	Резервы.Номенклатура КАК Номенклатура,
	|	ЕСТЬNULL(Резервы.КоличествоОстаток, 0) КАК КоличествоОстаток
	|ИЗ
	|	РегистрНакопления.РезервыТоваров.Остатки(&Момент,
	|		ЗаказКлиента = &ЗаказКлиента
	|			И Склад = &Склад
	|			И Номенклатура В (ВЫБРАТЬ Номенклатура ИЗ ВТНоменклатураДокумента)) КАК Резервы";
	
	Запрос.УстановитьПараметр("ТаблицаТоваров", ТаблицаТоваров);
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("Момент", ?(ЗначениеЗаполнено(Момент), Момент, ТекущаяДата()));
	Запрос.УстановитьПараметр("ЗаказКлиента", ЗаказКлиента);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Результат.Вставить(Выборка.Номенклатура, Выборка.КоличествоОстаток);
	КонецЦикла;
	
	Возврат Результат;

КонецФункции

#КонецЕсли
