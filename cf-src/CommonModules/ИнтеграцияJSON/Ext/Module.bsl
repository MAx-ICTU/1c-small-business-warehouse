Функция ПрочитатьJSONИзФайла(ПутьКФайлу) Экспорт

	Если ПустаяСтрока(ПутьКФайлу) Тогда
		ВызватьИсключение "Не указан путь к JSON-файлу.";
	КонецЕсли;
	
	Если НЕ ФайлСуществует(ПутьКФайлу) Тогда
		ВызватьИсключение СтрШаблон("Файл не найден: %1", ПутьКФайлу);
	КонецЕсли;
	
	ТекстJSON = Новый ЧтениеТекста(ПутьКФайлу, КодировкаТекста.UTF8).Прочитать();
	
	Чтение = Новый ЧтениеJSON;
	Чтение.УстановитьСтроку(ТекстJSON);
	
	Возврат ПрочитатьJSON(Чтение);

КонецФункции

Функция ЗагрузитьЗаказКлиентаИзJSON(ДанныеJSON) Экспорт

	Если ТипЗнч(ДанныеJSON) <> Тип("Структура") Тогда
		ВызватьИсключение "Ожидалась структура JSON-данных заказа.";
	КонецЕсли;
	
	ИмяКлиента = ПолучитьСтроковоеПоле(ДанныеJSON, "Клиент");
	ИмяСклада = ПолучитьСтроковоеПоле(ДанныеJSON, "Склад");
	ИмяВидаЦен = ПолучитьСтроковоеПоле(ДанныеJSON, "ВидЦен");
	
	Клиент = Справочники.Контрагенты.НайтиПоНаименованию(ИмяКлиента);
	Склад = Справочники.Склады.НайтиПоНаименованию(ИмяСклада);
	ВидЦен = Справочники.ВидыЦен.НайтиПоНаименованию(ИмяВидаЦен);
	
	Если НЕ ЗначениеЗаполнено(Клиент) Тогда
		ВызватьИсключение СтрШаблон("Клиент '%1' не найден.", ИмяКлиента);
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Склад) Тогда
		ВызватьИсключение СтрШаблон("Склад '%1' не найден.", ИмяСклада);
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(ВидЦен) Тогда
		ВызватьИсключение СтрШаблон("Вид цен '%1' не найден.", ИмяВидаЦен);
	КонецЕсли;
	
	Заказ = Документы.ЗаказКлиента.СоздатьДокумент();
	Заказ.Дата = ТекущаяДата();
	Заказ.Клиент = Клиент;
	Заказ.Склад = Склад;
	Заказ.ВидЦен = ВидЦен;
	Заказ.Статус = Перечисления.СтатусыЗаказов.Черновик;
	
	Товары = ПолучитьТабличныеДанные(ДанныеJSON, "Товары");
	
	Для каждого СтрокаJSON Из Товары Цикл
		НоменклатураИмя = ПолучитьСтроковоеПоле(СтрокаJSON, "Номенклатура");
		Номенклатура = Справочники.Номенклатура.НайтиПоНаименованию(НоменклатураИмя);
		
		Если НЕ ЗначениеЗаполнено(Номенклатура) Тогда
			ВызватьИсключение СтрШаблон("Номенклатура '%1' не найдена.", НоменклатураИмя);
		КонецЕсли;
		
		НоваяСтрока = Заказ.Товары.Добавить();
		НоваяСтрока.Номенклатура = Номенклатура;
		НоваяСтрока.Количество = ПолучитьЧисловоеПоле(СтрокаJSON, "Количество");
		НоваяСтрока.Цена = ПолучитьЧисловоеПоле(СтрокаJSON, "Цена");
		НоваяСтрока.КоличествоРезерв = НоваяСтрока.Количество;
	КонецЦикла;
	
	Заказ.Записать();
	
	Возврат Заказ.Ссылка;

КонецФункции

Функция ПолучитьСтроковоеПоле(Источник, ИмяПоля)
	Если НЕ Источник.Свойство(ИмяПоля) Тогда
		ВызватьИсключение СтрШаблон("В JSON отсутствует поле '%1'.", ИмяПоля);
	КонецЕсли;
	Возврат Строка(Источник[ИмяПоля]);
КонецФункции

Функция ПолучитьЧисловоеПоле(Источник, ИмяПоля)
	Если НЕ Источник.Свойство(ИмяПоля) Тогда
		ВызватьИсключение СтрШаблон("В JSON отсутствует поле '%1'.", ИмяПоля);
	КонецЕсли;
	Возврат Число(Источник[ИмяПоля]);
КонецФункции

Функция ПолучитьТабличныеДанные(Источник, ИмяПоля)
	Если НЕ Источник.Свойство(ИмяПоля) Тогда
		ВызватьИсключение СтрШаблон("В JSON отсутствует поле '%1'.", ИмяПоля);
	КонецЕсли;
	Если ТипЗнч(Источник[ИмяПоля]) <> Тип("Массив") Тогда
		ВызватьИсключение СтрШаблон("Поле '%1' должно быть массивом.", ИмяПоля);
	КонецЕсли;
	Возврат Источник[ИмяПоля];
КонецФункции

