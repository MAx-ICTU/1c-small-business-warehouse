Функция ПолучитьЦенуНоменклатуры(Номенклатура, ВидЦен, МоментЦены = Неопределено) Экспорт

	Если НЕ ЗначениеЗаполнено(Номенклатура) ИЛИ НЕ ЗначениеЗаполнено(ВидЦен) Тогда
		Возврат 0;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Цены.Цена КАК Цена
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&Момент,
	|		Номенклатура = &Номенклатура
	|			И ВидЦен = &ВидЦен) КАК Цены";
	
	Запрос.УстановитьПараметр("Момент", ?(ЗначениеЗаполнено(МоментЦены), МоментЦены, ТекущаяДата()));
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("ВидЦен", ВидЦен);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Цена;
	КонецЕсли;
	
	Возврат 0;

КонецФункции

Процедура ЗаполнитьЦеныВТабличнойЧасти(ТабличнаяЧасть, ВидЦен, МоментЦены = Неопределено) Экспорт

	Если ТабличнаяЧасть = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Для каждого СтрокаТовара Из ТабличнаяЧасть Цикл
		Если ЗначениеЗаполнено(СтрокаТовара.Номенклатура) Тогда
			Если НЕ ЗначениеЗаполнено(СтрокаТовара.Цена) ИЛИ СтрокаТовара.Цена = 0 Тогда
				СтрокаТовара.Цена = ПолучитьЦенуНоменклатуры(СтрокаТовара.Номенклатура, ВидЦен, МоментЦены);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

Процедура УстановитьЦенуНоменклатуры(Номенклатура, ВидЦен, Цена, МоментЦены = Неопределено) Экспорт

	Если НЕ ЗначениеЗаполнено(Номенклатура) ИЛИ НЕ ЗначениеЗаполнено(ВидЦен) Тогда
		Возврат;
	КонецЕсли;
	
	Набор = РегистрыСведений.ЦеныНоменклатуры.СоздатьНаборЗаписей();
	Запись = Набор.Добавить();
	Запись.Период = ?(ЗначениеЗаполнено(МоментЦены), МоментЦены, ТекущаяДата());
	Запись.Номенклатура = Номенклатура;
	Запись.ВидЦен = ВидЦен;
	Запись.Цена = Цена;
	Набор.Записать();

КонецПроцедуры

#КонецЕсли
