#Если Сервер Тогда

Функция СформироватьПечатнуюФорму(СсылкаДокумента) Экспорт

	Если НЕ ЗначениеЗаполнено(СсылкаДокумента) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ДокументОбъект = СсылкаДокумента.ПолучитьОбъект();
	
	ТабДок = Новый ТабличныйДокумент;
	ТабДок.АвтоМасштаб = Истина;
	ТабДок.ВывестиТекст("Заказ клиента", Новый Шрифт("Arial", 12, Истина));
	ТабДок.ВывестиТекст("");
	ТабДок.ВывестиТекст(СтрШаблон("Номер: %1", ДокументОбъект.Номер));
	ТабДок.ВывестиТекст(СтрШаблон("Дата: %1", Формат(ДокументОбъект.Дата, "ДЛФ=Д")));
	ТабДок.ВывестиТекст(СтрШаблон("Клиент: %1", ДокументОбъект.Клиент));
	ТабДок.ВывестиТекст(СтрШаблон("Склад: %1", ДокументОбъект.Склад));
	ТабДок.ВывестиТекст(СтрШаблон("Статус: %1", ДокументОбъект.Статус));
	ТабДок.ВывестиТекст("");
	
	ТабДок.ВывестиТекст("№\tНоменклатура\tКол-во\tЦена\tСумма", Новый Шрифт("Arial", 10, Истина));
	
	НомерСтроки = 0;
	Для каждого СтрокаТовара Из ДокументОбъект.Товары Цикл
		НомерСтроки = НомерСтроки + 1;
		ТабДок.ВывестиТекст(
			СтрШаблон("%1\t%2\t%3\t%4\t%5",
				НомерСтроки,
				СтрокаТовара.Номенклатура,
				Формат(СтрокаТовара.Количество, "ЧГ=15.3"),
				Формат(СтрокаТовара.Цена, "ЧГ=15.2"),
				Формат(СтрокаТовара.Сумма, "ЧГ=15.2")));
	КонецЦикла;
	
	ТабДок.ВывестиТекст("");
	ТабДок.ВывестиТекст(СтрШаблон("Итого: %1", Формат(ДокументОбъект.СуммаДокумента, "ЧГ=15.2")), Новый Шрифт("Arial", 10, Истина));
	
	Возврат ТабДок;

КонецФункции

Функция ПечатьДокумента(СсылкаДокумента) Экспорт
	Возврат СформироватьПечатнуюФорму(СсылкаДокумента);
КонецФункции

#КонецЕсли
