Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)

	Если НЕ ЗначениеЗаполнено(Статус) Тогда
		Статус = Перечисления.СтатусыЗаказов.Черновик;
	КонецЕсли;
	
	ПроверитьЗаполнениеШапки(Отказ);
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;

	Если Товары.Количество() = 0 Тогда
		Сообщить("Заказ клиента не может быть записан без строк в табличной части 'Товары'.", СтатусСообщения.Важное);
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ПересчитатьСуммыИРезервы();

КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)

	Если ЕстьДефицитДляРезерва() Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;

	Движения.РезервыТоваров.Записывать = Истина;
	
	ЕстьНерезервируемыеСтроки = Ложь;
	ЕстьРезерв = Ложь;
	
	Для каждого СтрокаТовара Из Товары Цикл
		
		КоличествоРезерва = ?(ЗначениеЗаполнено(СтрокаТовара.КоличествоРезерв), СтрокаТовара.КоличествоРезерв, 0);
		
		Если КоличествоРезерва <= 0 Тогда
			ЕстьНерезервируемыеСтроки = Истина;
			Продолжить;
		КонецЕсли;
		
		ЕстьРезерв = Истина;
		
		Движение = Движения.РезервыТоваров.Добавить();
		Движение.Период = Дата;
		Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
		Движение.Номенклатура = СтрокаТовара.Номенклатура;
		Движение.Склад = Склад;
		Движение.ЗаказКлиента = Ссылка;
		Движение.Количество = КоличествоРезерва;
	
	КонецЦикла;
	
	Если ЕстьРезерв И НЕ ЕстьНерезервируемыеСтроки Тогда
		Статус = Перечисления.СтатусыЗаказов.ВРезерве;
	Иначе
		Статус = Перечисления.СтатусыЗаказов.Подтвержден;
	КонецЕсли;

КонецПроцедуры

Процедура ПроверитьЗаполнениеШапки(Отказ)

	Если НЕ ЗначениеЗаполнено(Клиент) Тогда
		Сообщить("Не заполнен реквизит 'Клиент'.", СтатусСообщения.Важное);
		Отказ = Истина;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Склад) Тогда
		Сообщить("Не заполнен реквизит 'Склад'.", СтатусСообщения.Важное);
		Отказ = Истина;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ВидЦен) Тогда
		Сообщить("Не заполнен реквизит 'Вид цен'.", СтатусСообщения.Важное);
		Отказ = Истина;
	КонецЕсли;

КонецПроцедуры

Процедура ПересчитатьСуммыИРезервы()

	СуммаДокумента = 0;

	Для каждого СтрокаТовара Из Товары Цикл
		
		Если НЕ ЗначениеЗаполнено(СтрокаТовара.Количество) Тогда
			СтрокаТовара.Количество = 0;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(СтрокаТовара.Цена) Тогда
			СтрокаТовара.Цена = 0;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(СтрокаТовара.КоличествоРезерв) Тогда
			СтрокаТовара.КоличествоРезерв = СтрокаТовара.Количество;
		КонецЕсли;
		
		Если СтрокаТовара.КоличествоРезерв > СтрокаТовара.Количество Тогда
			СтрокаТовара.КоличествоРезерв = СтрокаТовара.Количество;
		КонецЕсли;
		
		СтрокаТовара.Сумма = Окр(СтрокаТовара.Количество * СтрокаТовара.Цена, 2);
		СуммаДокумента = СуммаДокумента + СтрокаТовара.Сумма;
	
	КонецЦикла;

	СуммаДокумента = Окр(СуммаДокумента, 2);

КонецПроцедуры

Функция ЕстьДефицитДляРезерва()

	ТаблицаТоваров = Товары.Выгрузить();
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	СУММА(Товары.КоличествоРезерв) КАК КоличествоРезерв
	|ПОМЕСТИТЬ ВТРезервДокумента
	|ИЗ
	|	&ТаблицаТоваров КАК Товары
	|ГДЕ
	|	Товары.КоличествоРезерв > 0
	|СГРУППИРОВАТЬ ПО
	|	Товары.Номенклатура
	|;
	|
	|ВЫБРАТЬ
	|	ВТРезервДокумента.Номенклатура КАК Номенклатура,
	|	ВТРезервДокумента.КоличествоРезерв КАК КоличествоРезерв,
	|	ЕСТЬNULL(Остатки.КоличествоОстаток, 0) КАК КоличествоОстаток,
	|	ЕСТЬNULL(Резервы.КоличествоОстаток, 0) КАК КоличествоУжеВРезерве
	|ИЗ
	|	ВТРезервДокумента КАК ВТРезервДокумента
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТоваров.Остатки(&Момент,
	|			Склад = &Склад
	|				И Номенклатура В (ВЫБРАТЬ Номенклатура ИЗ ВТРезервДокумента)) КАК Остатки
	|		ПО ВТРезервДокумента.Номенклатура = Остатки.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТоваров.Остатки(&Момент,
	|			Склад = &Склад
	|				И Номенклатура В (ВЫБРАТЬ Номенклатура ИЗ ВТРезервДокумента)
	|				И ЗаказКлиента <> &ТекущийЗаказ) КАК Резервы
	|		ПО ВТРезервДокумента.Номенклатура = Резервы.Номенклатура
	|ГДЕ
	|	ВТРезервДокумента.КоличествоРезерв > (ЕСТЬNULL(Остатки.КоличествоОстаток, 0) - ЕСТЬNULL(Резервы.КоличествоОстаток, 0))";
	
	Запрос.УстановитьПараметр("ТаблицаТоваров", ТаблицаТоваров);
	Запрос.УстановитьПараметр("Момент", Дата);
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("ТекущийЗаказ", Ссылка);
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Если НЕ Выборка.Следующий() Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Сообщить("Невозможно провести заказ: недостаточно доступного количества для резерва.", СтатусСообщения.Важное);
	
	Пока Истина Цикл
		Доступно = Выборка.КоличествоОстаток - Выборка.КоличествоУжеВРезерве;
		Дефицит = Выборка.КоличествоРезерв - Доступно;
		Сообщить(
			СтрШаблон("Номенклатура '%1': к резерву %2, доступно %3, дефицит %4.",
				Выборка.Номенклатура,
				Формат(Выборка.КоличествоРезерв, "ЧГ=15.3"),
				Формат(Доступно, "ЧГ=15.3"),
				Формат(Дефицит, "ЧГ=15.3")),
			СтатусСообщения.Важное);
		
		Если НЕ Выборка.Следующий() Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Истина;

КонецФункции
