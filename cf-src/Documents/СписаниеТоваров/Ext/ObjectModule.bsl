Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)

	Если НЕ ЗначениеЗаполнено(Склад) Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Не заполнен реквизит 'Склад'.");
		Отказ = Истина;
	КонецЕсли;
	
	Если Товары.Количество() = 0 Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Документ не может быть записан без строк в табличной части 'Товары'.");
		Отказ = Истина;
	КонецЕсли;

КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)

	Если УправлениеЗапасами.ЕстьДефицитОстатков(Товары.Выгрузить(), Склад, Дата,
		"Невозможно провести списание: недостаточно товара на складе.", Истина) Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;

	Движения.ОстаткиТоваров.Записывать = Истина;
	
	Для каждого СтрокаТовара Из Товары Цикл
		Если СтрокаТовара.Количество <= 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Движение = Движения.ОстаткиТоваров.Добавить();
		Движение.Период = Дата;
		Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
		Движение.Номенклатура = СтрокаТовара.Номенклатура;
		Движение.Склад = Склад;
		Движение.Количество = СтрокаТовара.Количество;
	КонецЦикла;

КонецПроцедуры
