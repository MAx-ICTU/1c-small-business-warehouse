Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)

	Если НЕ ЗначениеЗаполнено(СкладОтправитель) Тогда
		Сообщить("Не заполнен реквизит 'Склад отправитель'.", СтатусСообщения.Важное);
		Отказ = Истина;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(СкладПолучатель) Тогда
		Сообщить("Не заполнен реквизит 'Склад получатель'.", СтатусСообщения.Важное);
		Отказ = Истина;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СкладОтправитель) И ЗначениеЗаполнено(СкладПолучатель)
		И СкладОтправитель = СкладПолучатель Тогда
		Сообщить("Склад отправитель и склад получатель должны отличаться.", СтатусСообщения.Важное);
		Отказ = Истина;
	КонецЕсли;
	
	Если Товары.Количество() = 0 Тогда
		Сообщить("Документ не может быть записан без строк в табличной части 'Товары'.", СтатусСообщения.Важное);
		Отказ = Истина;
	КонецЕсли;

КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)

	Если ЕстьДефицитОстатков(СкладОтправитель) Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;

	Движения.ОстаткиТоваров.Записывать = Истина;
	
	Для каждого СтрокаТовара Из Товары Цикл
		
		Если СтрокаТовара.Количество <= 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ДвижениеРасход = Движения.ОстаткиТоваров.Добавить();
		ДвижениеРасход.Период = Дата;
		ДвижениеРасход.ВидДвижения = ВидДвиженияНакопления.Расход;
		ДвижениеРасход.Номенклатура = СтрокаТовара.Номенклатура;
		ДвижениеРасход.Склад = СкладОтправитель;
		ДвижениеРасход.Количество = СтрокаТовара.Количество;
		
		ДвижениеПриход = Движения.ОстаткиТоваров.Добавить();
		ДвижениеПриход.Период = Дата;
		ДвижениеПриход.ВидДвижения = ВидДвиженияНакопления.Приход;
		ДвижениеПриход.Номенклатура = СтрокаТовара.Номенклатура;
		ДвижениеПриход.Склад = СкладПолучатель;
		ДвижениеПриход.Количество = СтрокаТовара.Количество;
	
	КонецЦикла;

КонецПроцедуры

Функция ЕстьДефицитОстатков(СкладПроверки)

	ТаблицаТоваров = Товары.Выгрузить();
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	СУММА(Товары.Количество) КАК КоличествоТребуется
	|ПОМЕСТИТЬ ВТТоварыДокумента
	|ИЗ
	|	&ТаблицаТоваров КАК Товары
	|СГРУППИРОВАТЬ ПО
	|	Товары.Номенклатура
	|;
	|
	|ВЫБРАТЬ
	|	ВТТоварыДокумента.Номенклатура КАК Номенклатура,
	|	ВТТоварыДокумента.КоличествоТребуется КАК КоличествоТребуется,
	|	ЕСТЬNULL(Остатки.КоличествоОстаток, 0) КАК КоличествоОстаток
	|ИЗ
	|	ВТТоварыДокумента КАК ВТТоварыДокумента
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТоваров.Остатки(&Момент,
	|			Склад = &Склад
	|				И Номенклатура В (ВЫБРАТЬ Номенклатура ИЗ ВТТоварыДокумента)) КАК Остатки
	|		ПО ВТТоварыДокумента.Номенклатура = Остатки.Номенклатура
	|ГДЕ
	|	ВТТоварыДокумента.КоличествоТребуется > ЕСТЬNULL(Остатки.КоличествоОстаток, 0)";
	
	Запрос.УстановитьПараметр("ТаблицаТоваров", ТаблицаТоваров);
	Запрос.УстановитьПараметр("Момент", Дата);
	Запрос.УстановитьПараметр("Склад", СкладПроверки);
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Если НЕ Выборка.Следующий() Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Сообщить("Невозможно провести перемещение: недостаточно товара на складе отправителе.", СтатусСообщения.Важное);
	
	Пока Истина Цикл
		Дефицит = Выборка.КоличествоТребуется - Выборка.КоличествоОстаток;
		Сообщить(
			СтрШаблон("Номенклатура '%1': требуется %2, остаток %3, дефицит %4.",
				Выборка.Номенклатура,
				Формат(Выборка.КоличествоТребуется, "ЧГ=15.3"),
				Формат(Выборка.КоличествоОстаток, "ЧГ=15.3"),
				Формат(Дефицит, "ЧГ=15.3")),
			СтатусСообщения.Важное);
		
		Если НЕ Выборка.Следующий() Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Истина;

КонецФункции
