Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)

	Если НЕ ЗначениеЗаполнено(СкладОтправитель) Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Не заполнен реквизит 'Склад отправитель'.");
		Отказ = Истина;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(СкладПолучатель) Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Не заполнен реквизит 'Склад получатель'.");
		Отказ = Истина;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СкладОтправитель) И ЗначениеЗаполнено(СкладПолучатель)
		И СкладОтправитель = СкладПолучатель Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Склад отправитель и склад получатель должны отличаться.");
		Отказ = Истина;
	КонецЕсли;
	
	Если Товары.Количество() = 0 Тогда
		ОбщегоНазначения.СообщитьОбОшибке("Документ не может быть записан без строк в табличной части 'Товары'.");
		Отказ = Истина;
	КонецЕсли;

КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)

	Если УправлениеЗапасами.ЕстьДефицитОстатков(Товары.Выгрузить(), СкладОтправитель, Дата,
		"Невозможно провести перемещение: недостаточно товара на складе отправителе.", Истина) Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;

	Движения.ОстаткиТоваров.Записывать = Истина;
	
	Для каждого СтрокаТовара Из Товары Цикл
		Если СтрокаТовара.Количество <= 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ДвижениеРасход = Движения.ОстаткиТоваров.Добавить();
		ДвижениеРасход.Период = Дата;
		ДвижениеРасход.ВидДвижения = ВидДвиженияНакопления.Расход;
		ДвижениеРасход.Номенклатура = СтрокаТовара.Номенклатура;
		ДвижениеРасход.Склад = СкладОтправитель;
		ДвижениеРасход.Количество = СтрокаТовара.Количество;
		
		ДвижениеПриход = Движения.ОстаткиТоваров.Добавить();
		ДвижениеПриход.Период = Дата;
		ДвижениеПриход.ВидДвижения = ВидДвиженияНакопления.Приход;
		ДвижениеПриход.Номенклатура = СтрокаТовара.Номенклатура;
		ДвижениеПриход.Склад = СкладПолучатель;
		ДвижениеПриход.Количество = СтрокаТовара.Количество;
	КонецЦикла;

КонецПроцедуры
