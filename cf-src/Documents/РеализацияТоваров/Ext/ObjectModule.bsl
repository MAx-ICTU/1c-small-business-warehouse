Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)

	ПроверитьЗаполнениеШапки(Отказ);
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;

	Если Товары.Количество() = 0 Тогда
		Сообщить("Реализация не может быть записана без строк в табличной части 'Товары'.", СтатусСообщения.Важное);
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ПересчитатьСуммыДокумента();

КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)

	Если ЕстьДефицитОстатков() Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;

	Движения.ОстаткиТоваров.Записывать = Истина;
	Движения.РезервыТоваров.Записывать = ЗначениеЗаполнено(ЗаказОснование);
	
	ОстаткиРезерваПоЗаказу = ПолучитьОстаткиРезерваПоЗаказу();
	
	Для каждого СтрокаТовара Из Товары Цикл
		
		Если СтрокаТовара.Количество <= 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Движение = Движения.ОстаткиТоваров.Добавить();
		Движение.Период = Дата;
		Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
		Движение.Номенклатура = СтрокаТовара.Номенклатура;
		Движение.Склад = Склад;
		Движение.Количество = СтрокаТовара.Количество;
		
		Если ЗначениеЗаполнено(ЗаказОснование) Тогда
			КРезерву = 0;
			
			Если ОстаткиРезерваПоЗаказу.Свойство(СтрокаТовара.Номенклатура, КРезерву) Тогда
				Если КРезерву > 0 Тогда
					КоличествоСнятия = Мин(СтрокаТовара.Количество, КРезерву);
					
					ДвижениеРезерва = Движения.РезервыТоваров.Добавить();
					ДвижениеРезерва.Период = Дата;
					ДвижениеРезерва.ВидДвижения = ВидДвиженияНакопления.Расход;
					ДвижениеРезерва.Номенклатура = СтрокаТовара.Номенклатура;
					ДвижениеРезерва.Склад = Склад;
					ДвижениеРезерва.ЗаказКлиента = ЗаказОснование;
					ДвижениеРезерва.Количество = КоличествоСнятия;
					
					ОстаткиРезерваПоЗаказу.Вставить(СтрокаТовара.Номенклатура, КРезерву - КоличествоСнятия);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	
	КонецЦикла;

КонецПроцедуры

Процедура ПроверитьЗаполнениеШапки(Отказ)

	Если НЕ ЗначениеЗаполнено(Клиент) Тогда
		Сообщить("Не заполнен реквизит 'Клиент'.", СтатусСообщения.Важное);
		Отказ = Истина;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Склад) Тогда
		Сообщить("Не заполнен реквизит 'Склад'.", СтатусСообщения.Важное);
		Отказ = Истина;
	КонецЕсли;

КонецПроцедуры

Процедура ПересчитатьСуммыДокумента()

	СуммаДокумента = 0;

	Для каждого СтрокаТовара Из Товары Цикл
		
		Если НЕ ЗначениеЗаполнено(СтрокаТовара.Количество) Тогда
			СтрокаТовара.Количество = 0;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(СтрокаТовара.Цена) Тогда
			СтрокаТовара.Цена = 0;
		КонецЕсли;
		
		СтрокаТовара.Сумма = Окр(СтрокаТовара.Количество * СтрокаТовара.Цена, 2);
		СуммаДокумента = СуммаДокумента + СтрокаТовара.Сумма;
	
	КонецЦикла;

	СуммаДокумента = Окр(СуммаДокумента, 2);

КонецПроцедуры

Функция ЕстьДефицитОстатков()

	ТаблицаТоваров = Товары.Выгрузить();
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	СУММА(Товары.Количество) КАК КоличествоТребуется
	|ПОМЕСТИТЬ ВТТоварыДокумента
	|ИЗ
	|	&ТаблицаТоваров КАК Товары
	|СГРУППИРОВАТЬ ПО
	|	Товары.Номенклатура
	|;
	|
	|ВЫБРАТЬ
	|	ВТТоварыДокумента.Номенклатура КАК Номенклатура,
	|	ВТТоварыДокумента.КоличествоТребуется КАК КоличествоТребуется,
	|	ЕСТЬNULL(Остатки.КоличествоОстаток, 0) КАК КоличествоОстаток
	|ИЗ
	|	ВТТоварыДокумента КАК ВТТоварыДокумента
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТоваров.Остатки(&Момент,
	|			Склад = &Склад
	|				И Номенклатура В (ВЫБРАТЬ Номенклатура ИЗ ВТТоварыДокумента)) КАК Остатки
	|		ПО ВТТоварыДокумента.Номенклатура = Остатки.Номенклатура
	|ГДЕ
	|	ВТТоварыДокумента.КоличествоТребуется > ЕСТЬNULL(Остатки.КоличествоОстаток, 0)";
	
	Запрос.УстановитьПараметр("ТаблицаТоваров", ТаблицаТоваров);
	Запрос.УстановитьПараметр("Момент", Дата);
	Запрос.УстановитьПараметр("Склад", Склад);
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Если НЕ Выборка.Следующий() Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Сообщить("Невозможно провести реализацию: недостаточно товара на складе.", СтатусСообщения.Важное);
	
	Пока Истина Цикл
		Дефицит = Выборка.КоличествоТребуется - Выборка.КоличествоОстаток;
		Сообщить(
			СтрШаблон("Номенклатура '%1': требуется %2, остаток %3, дефицит %4.",
				Выборка.Номенклатура,
				Формат(Выборка.КоличествоТребуется, "ЧГ=15.3"),
				Формат(Выборка.КоличествоОстаток, "ЧГ=15.3"),
				Формат(Дефицит, "ЧГ=15.3")),
			СтатусСообщения.Важное);
		
		Если НЕ Выборка.Следующий() Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Истина;

КонецФункции

Функция ПолучитьОстаткиРезерваПоЗаказу()

	Результат = Новый Соответствие;
	
	Если НЕ ЗначениеЗаполнено(ЗаказОснование) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ТаблицаТоваров = Товары.Выгрузить();
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РАЗЛИЧНЫЕ
	|	Товары.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ВТНоменклатураДокумента
	|ИЗ
	|	&ТаблицаТоваров КАК Товары
	|;
	|
	|ВЫБРАТЬ
	|	Резервы.Номенклатура КАК Номенклатура,
	|	ЕСТЬNULL(Резервы.КоличествоОстаток, 0) КАК КоличествоОстаток
	|ИЗ
	|	РегистрНакопления.РезервыТоваров.Остатки(&Момент,
	|		ЗаказКлиента = &ЗаказКлиента
	|			И Склад = &Склад
	|			И Номенклатура В (ВЫБРАТЬ Номенклатура ИЗ ВТНоменклатураДокумента)) КАК Резервы";
	
	Запрос.УстановитьПараметр("ТаблицаТоваров", ТаблицаТоваров);
	Запрос.УстановитьПараметр("Момент", Дата);
	Запрос.УстановитьПараметр("ЗаказКлиента", ЗаказОснование);
	Запрос.УстановитьПараметр("Склад", Склад);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Результат.Вставить(Выборка.Номенклатура, Выборка.КоличествоОстаток);
	КонецЦикла;
	
	Возврат Результат;

КонецФункции
